{
  "name": "react-pro-sidebar",
  "version": "1.1.0",
  "description": "high level and customizable side navigation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": "https://github.com/azouaoui-med/react-pro-sidebar.git",
  "author": "Mohamed Azouaoui <azouaoui.med@gmail.com>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "build": "tsup",
    "start": "tsup --watch",
    "storybook": "storybook dev -p 9001",
    "build:storybook": "storybook build",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "yarn lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky",
    "gh-pages": "yarn build:storybook && gh-pages -d storybook-static"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@storybook/addon-docs": "^10",
    "@storybook/react": "^10",
    "@storybook/react-vite": "^10",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "^18.0.25",
    "@types/react-dom": "^18.0.9",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^4",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-plugin-jest-dom": "^5",
    "eslint-plugin-jsx-a11y": "^6",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-testing-library": "^7",
    "gh-pages": "^4.0.0",
    "globals": "^17.6.0",
    "husky": "^9",
    "jsdom": "^29.1.1",
    "lint-staged": "^17",
    "prettier": "^2.5.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10",
    "tsup": "^8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8",
    "vite": "^6",
    "vitest": "^4"
  },
  "keywords": [
    "react-component",
    "react-sidebar",
    "layout",
    "sidebar",
    "menu",
    "submenu",
    "component",
    "collapsed",
    "rtl"
  ],
  "dependencies": {
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "@popperjs/core": "^2.11.6",
    "classnames": "^2.3.2"
  }
}
